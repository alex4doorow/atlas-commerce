  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "const tokenUrl = 'localhost:8080/realms/atlas/protocol/openid-connect/token';\r",
          "\r",
          "const clientId = 'atlas-api';\r",
          "const username = 'alex4doorow';\r",
          "const password = '1';\r",
          "\r",
          "const getTokenRequest = {\r",
          "  method: 'POST',\r",
          "  header: 'Content-Type:application/x-www-form-urlencoded',  \r",
          "  url: tokenUrl,\r",
          "  body: {\r",
          "      mode: 'urlencoded',\r",
          "      urlencoded: [\r",
          "          { key: 'grant_type', value: 'password' },\r",
          "          { key: 'client_id', value: clientId },\r",
          "          { key: 'username', value: username },\r",
          "          { key: 'password', value: password }\r",
          "      ]\r",
          "  }\r",
          "};\r",
          "\r",
          "pm.sendRequest(getTokenRequest, (err, response) => {\r",
          "  const jsonResponse = response.json();\r",
          "  const newAccessToken = jsonResponse.access_token;\r",
          "  pm.collectionVariables.set('access_token', newAccessToken);\r",
          "});"
        ]
      }
    },
